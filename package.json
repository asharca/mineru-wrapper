{
  "name": "mineru-wrapper",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "dev:server": "cd packages/server && bun run --watch index.ts",
    "dev:web": "cd packages/web && bunx vite",
    "dev": "bun run dev:server & bun run dev:web",
    "build:web": "cd packages/web && bunx vite build",
    "build": "bun run build:web"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
